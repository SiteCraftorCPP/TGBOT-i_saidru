BOT_TOKEN=
BOT_USERNAME=My1Documents_bot
ADMIN_IDS=7600749840,5823290314

DEEPSEEK_API_KEYS=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_TEMPERATURE=0.2

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/my_documents_bot
REDIS_URL=redis://localhost:6379/0

TELEGRAM_PROXY_URL=
PAYMENTS_ENABLED=false
# Для платежей через Telegram-счёт (RUB, LabeledPrice): сумма ×100 как копейки (см. Telegram currencies.json, exp=2).
# Также есть min_amount для RUB — не ставьте слишком дешево (ориентир ~88 ₽+, см. docs/PAYMENTS_TELEGRAM.md).
DOCUMENT_PRICE_RUB=100
SUBSCRIPTION_PRICE_RUB=499
# Подписка (subscription_until): дать ли месяц без отдельной оплаты за каждый документ. По умолчанию false — безлимит только у ADMIN_IDS.
SUBSCRIPTION_INCLUDES_UNLIMITED_DOCS=false

# ЮKassa API (HTTP Basic): https://yookassa.ru/developers/using-api/interaction-format#auth
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# return_url для confirmation.type=redirect при создании платежа
YOOKASSA_RETURN_URL=

# HTTP webhook локально (аiohttp рядом с polling). Перенаправьте HTTPS с уведомлений ЮKassa на host:port/path
YOOKASSA_WEBHOOK_HOST=127.0.0.1
YOOKASSA_WEBHOOK_PORT=0
YOOKASSA_WEBHOOK_PATH=/yookassa/webhook

# Нативные платежи Telegram (send_invoice / PreCheckoutQuery). Токен из BotFather → Payments после привязки ЮKassa.
# При PAYMENTS_ENABLED=true и этом токене используется оплата внутри Telegram; если токена нет — сценарий по ссылке ЮKassa (нужны YOOKASSA_* и опционально webhook).
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
# ЮKassa + Telegram-счёт: код системы налогообложения для receipt в provider_data (1–6 по докам ЮKassa). 0 — чек не прикладываем.
YOOKASSA_TAX_SYSTEM_CODE=0
# Код ставки НДС в позиции чека (номер из списка ЮKassa для receipt.items[].vat_code; по умолчанию 1).
YOOKASSA_VAT_CODE=1

LIBREOFFICE_PATH=soffice
STORAGE_DIR=storage/generated
TEMPLATES_DIR=templates
